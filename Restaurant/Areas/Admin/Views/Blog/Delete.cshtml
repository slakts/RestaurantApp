@model Restaurant.Models.Entities.Blog

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<h3 class="text-center">Bu blogu silmek istediğinizden emin misiniz?</h3>
<br>
<div class="row justify-content-center">
    <div class="col-md-6">
        <h4>Blog Bilgileri</h4>
        <hr />
        <br>
        <dl class="row">
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Title)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Title)
            </dd>
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Name)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Name)
            </dd>
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Email)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Email)
            </dd>
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Image)
            </dt>
            <dd class="col-sm-8">
                <img src="@Url.Content(Model.Image)" alt="Blog Resmi" class="table-img" />
            </dd>
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Onay)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Onay)
            </dd>
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Mesaj)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Mesaj)
            </dd>
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Tarih)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Tarih)
            </dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="form-group text-center">
                <input type="submit" value="Sil" class="btn btn-danger" /> |
                <a asp-action="Index" class="btn btn-primary">Listeye Geri Dön</a>
            </div>
        </form>
    </div>
</div>
